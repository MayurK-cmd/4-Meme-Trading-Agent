# ── 4MemePilot Agent Configuration ─────────────────────────────────────────────
# Mainnet trading configuration for 4.meme (BNB Smart Chain)

# Backend connection (required for on-chain audit logging)
BACKEND_URL=http://localhost:3001
AGENT_API_SECRET=aa78d2bdf36c0144bbf31ff05450d8d183f144b03a76a65e811e18af47d83480

# AI APIs (required for trading decisions)
GEMINI_API_KEY=<your_google_gemini_api_key>
ELFA_API_KEY=<your_elfa_ai_api_key>

# BSC Wallet (required for trading)
# WARNING: Real BNB will be spent when DRY_RUN=false!
WALLET_PRIVATE_KEY=<your_bsc_wallet_private_key>

# BSC RPC (optional - defaults to public mainnet)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Safety override - SET TO FALSE for real mainnet trading
# DRY_RUN=true   = Simulated trades (safe testing)
# DRY_RUN=false  = REAL BNB transactions on mainnet!
DRY_RUN=true

# Token Discovery Mode
# Options: "trending" | "new" | "watchlist"
# - trending: Fetch from 4.meme API (requires auth, may not work)
# - new: Fetch new launches (requires auth, may not work)
# - watchlist: Use manually configured token addresses (recommended)
SCAN_MODE=watchlist

# Watchlist - comma-separated token contract addresses (required for watchlist mode)
# Example: WATCHLIST=0x1234...,0x5678...,0xabcd...
WATCHLIST=

# Trading Configuration
MAX_POSITION_BNB=0.1       # Max BNB per trade
MAX_POSITION_USD=60        # Max USD per trade
MIN_CONFIDENCE=0.55        # Minimum AI confidence to trade
STOP_LOSS_PCT=5.0          # Stop loss percentage
TAKE_PROFIT_PCT=10.0       # Take profit percentage
MAX_OPEN_POSITIONS=3       # Maximum concurrent positions
MIN_LIQUIDITY_USD=5000     # Minimum token liquidity
MAX_RUG_RISK=50            # Maximum rug risk score (0-100)
BC_MIN_PCT=20              # Minimum bonding curve %
BC_MAX_PCT=80              # Maximum bonding curve %

# Agent Loop
LOOP_INTERVAL_SECONDS=300  # Seconds between trading cycles (5 min default)
