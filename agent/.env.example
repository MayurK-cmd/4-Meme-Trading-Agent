# ── 4MemePilot Agent Configuration ─────────────────────────────────────────────
# Only essential settings - all other config comes from backend (MongoDB)

# Backend connection (required)
BACKEND_URL=http://localhost:3001
AGENT_API_SECRET=aa78d2bdf36c0144bbf31ff05450d8d183f144b03a76a65e811e18af47d83480

# AI APIs (required for trading decisions)
GEMINI_API_KEY=<your_google_gemini_api_key>
ELFA_API_KEY=<your_elfa_ai_api_key>

# BSC Wallet (required for trading)
# Note: Wallet address is fetched from backend onboarding, only private key needed here
WALLET_PRIVATE_KEY=<your_bsc_wallet_private_key>

# BSC RPC (optional - defaults to public mainnet)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Safety override (optional - defaults to true)
DRY_RUN=true
